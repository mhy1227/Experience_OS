# 复制为 .env.local 并填入真实值(.env.local 已被 .gitignore,不会提交)
# 演示用内置模型:启动时若用户未配置,会自动注入这份配置到浏览器 localStorage
VITE_DEEPSEEK_API_KEY=
# 官方:https://api.deepseek.com  ;中转站(OpenAI 兼容)填到 /v1,例如 https://www.packyapi.com/v1
VITE_DEEPSEEK_BASE_URL=https://api.deepseek.com
# 官方:deepseek-chat ;中转站可用其提供的模型名,例如 deepseek-v4-flash
VITE_DEEPSEEK_MODEL=deepseek-chat
